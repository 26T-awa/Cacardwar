give @a written_book[written_book_content={author:"\u00a7k_26T",title:"\u00a7b\u00a7l牌\u00a76\u00a7l牌\u00a7r\u00a7a大作战\u00a7r 信息书",pages:[{text:"□■□■□\u00a7b\u00a7l牌\u00a76\u00a7l牌\u00a7a大作战\u00a7r□■□■□■\n目录:\n",extra:[{text:" \u00a7n1.规则\n",click_event:{action:"change_page",page:2},hover_event:{action:"show_text",value:"点击跳转"}},{text:" \u00a7n2.物品效果及合成配方\n",click_event:{action:"change_page",page:5},hover_event:{action:"show_text",value:"点击跳转"}},{text:" \u00a7n3.卡组选择[每局必选]\n",click_event:{action:"change_page",page:21},hover_event:{action:"show_text",value:"点击跳转"}},{text:" \u00a7n4.准备[每局必选]\n",click_event:{action:"change_page",page:25},hover_event:{action:"show_text",value:"点击跳转"}}]},{text:"\u00a7l规则\u00a7r1/3\n\u00a771.开始时双方随机抽取先后手，先手获得\u00a7a4\u00a77张卡牌，后手及后续双方获得\u00a7a5\u00a77张卡牌。\n2.双方初始拥有\u00a7c20点生命值\u00a77，\u00a76胜利目标：令对手生命值为零\u00a7r\u00a77。\n3.按照\u00a76合成配方\u00a7r\u00a77摆放卡牌来进行\u00a7c攻击\u00a77、\u00a7d回复\u00a77、\u00a73防御\u00a77等。\n4.每回合结束后你将\u00a7c失去所有卡牌\u00a77。\n5.你可以在\u00a73末地传送门框架\u00a77上的物品展示框存放\u00a7a一张卡牌\u00a77。"},{text:"\u00a7l规则\u00a7r2/3\n\u00a776.你可以自由选择\u00a7a4\u00a77套卡组：\u00a7c进攻型\u00a77、\u00a7d持久型\u00a77、\u00a73召唤型\u00a77、\u00a7a均衡型\u00a77。\n\u00a777.放置卡牌时请慎重，因为放错后移动卡牌将导致\u00a7c该卡牌消失\u00a77。\n\u00a778.因技术原因\u00a7c请勿丢弃、带出卡牌，请勿破坏场地（尤其物品展示框）！\n\u00a779.游戏开始前请\u00a76清空物品栏\u00a77以防止物品消失。\n10.一个存档只允许一个场地存在！"},{text:"\u00a7l规则\u00a7r3/3\n\u00a7711.确保游戏难度\u00a7c不为和平\u00a7r\u00a77，否则召唤物将无法生成。\n\u00a7712.\u00a7n玩得开心！(gl & hf)"},{text:"\u00a7l物品效果及合成配方\u00a7r1/16\n\n\u00a761.铁剑：造成\u00a7c6点伤害\n\u00a77  ○■○\n  ○■○    →  铁剑\n  ○| ○\n■:铁锭,|:木棍，任意一列\n\n\u00a762.金剑：造成\u00a7c5点伤害\n\u00a77  ○■○\n  ○■○    →  金剑\n  ○| ○\n■:金锭,|:木棍，任意一列"},{text:"\u00a7l物品效果及合成配方\u00a7r2/16\n\n\u00a763.钻石剑：造成\u00a7c7点伤害\n\u00a77  ○■○\n  ○■○    →  钻石剑\n  ○| ○\n■:钻石,|:木棍，任意一列\n\n\u00a764.面包：回复\u00a7d5点生命值\n\u00a77  ○○○\n  YYY    →  面包\n  ○○○\nY:小麦，任意一行\n"},{text:"\u00a7l物品效果及合成配方\u00a7r3/16\n\n\u00a765.金苹果：回复\u00a7d30点生命值\n\u00a77  ○■○\n  ■●■    →  金苹果\n  ○■○\n■:金锭,●:苹果\n\n\u00a766.苹果：回复\u00a7d3点生命值\n\u00a77  ○●○\n  ○○○\n  ○○○\n无合成配方，可直接使用，需放在荧光物品展示框\n"},{text:"\u00a7l物品效果及合成配方\u00a7r4/16\n\n\u00a767.火弹：造成\u00a7c7点伤害\u00a76，且\u00a73无视铁护盾\n\u00a77  ○○○\n  ●●●    →  火弹\n  ○○○\n●:火药，任意一行"},{text:"\u00a7l物品效果及合成配方\u00a7r5/16\n\n\u00a768.烈焰剑：造成\u00a7c6点伤害\u00a76，且\u00a73无视铁护盾\n\u00a77  ○●○\n  ○●○    →  烈焰剑\n  ○■○\n●:火药,■:原木，任意一列"},{text:"\u00a7l物品效果及合成配方\u00a7r6/16\n\n\u00a769.炸药桶：造成\u00a7c8点伤害\u00a76，且\u00a73无视铁护盾\n\u00a77  ■M■\n  ■●■    →  炸药桶\n  ■■■\n●:火药,■:木板,M:铁锭"},{text:"\u00a7l物品效果及合成配方\u00a7r7/16\n\n\u00a7610.巨型炸药桶：造成\u00a7c14点伤害\u00a76，且\u00a73无视铁护盾\n\u00a77  ●M●\n  ■●■    →  巨型炸药桶\n  ●■●\n●:火药,■:木板,M:铁锭\n"},{text:"\u00a7l物品效果及合成配方\u00a7r8/16\n\n\u00a7611.盾牌：形成\u00a73免疫护盾\u00a76，\u00a73免疫一次剑伤（铁盾牌）或火伤（金盾牌），铁盾牌和金盾牌可同时存在\n\u00a77  ■M■\n  ■■■    →  铁/金盾牌\n  ○■○\n■:木板,M:铁锭/金锭\n"},{text:"\u00a7l物品效果及合成配方\u00a7r9/16\n\n\u00a7612.铁镐：\u00a73夺取对方的一个物品\n\u00a77  ■■■\n  ○| ○    →  铁镐\n  ○| ○\n■:铁锭,| :木棍\n"},{text:"\u00a7l物品效果及合成配方\u00a7r10/16\n\n\u00a7613.钻石镐：\u00a73夺取对方的一个物品，并获得额外物品\n\u00a77  ■■■\n  ○| ○    →  钻石镐\n  ○| ○\n■:钻石,| :木棍\n"},{text:"\u00a7l物品效果及合成配方\u00a7r11/16\n\n\u00a7614.原木：可合成\u00a7e4\u00a76个木板\n\u00a77  ○●○\n  ○○○    →  木板*4\n  ○○○\n无合成配方，可直接使用，需放在荧光物品展示框\n\n\u00a7615.木板：可合成\u00a7e2\u00a76个木棍\n\u00a77  ○■○\n  ○■○    →  木棍*2\n  ○○○\n■:木板，固定位置\n"},{text:"\u00a7l物品效果及合成配方\u00a7r12/16\n\n\u00a7616.腐肉：回复\u00a7d2点生命值\u00a76，并获得\u00a7c饥饿\u00a76效果（回复类道具效果减半），效果持续到下一次使用回复类道具\n\u00a77  ○●○\n  ○○○\n  ○○○\n无合成配方，可直接使用，需放在荧光物品展示框\n"},{text:"\u00a7l物品效果及合成配方\u00a7r13/16\n\n\u00a7317.召唤物·僵尸：召唤一只僵尸，每回合结束后造成\u00a7c3点伤害\u00a73，持续\u00a732回合\n\u00a77  | | |\n  ○| ○    →  生成僵尸\n  ■●■\n■:原木,| :木棍,●:腐肉\n"},{text:"\u00a7l物品效果及合成配方\u00a7r14/16\n\n\u00a7318.召唤物·商人：召唤一名商人，每回合开始后获得额外\u00a7a2张卡牌\u00a73，持续\u00a734回合\n\u00a77  | | |\n  ○♦○    →  生成商人\n  ■●□\n| :木棍,■:金锭,●:钻石,□:铁锭,♦:赌徒的交易\n"},{text:"\u00a7l物品效果及合成配方\u00a7r15/16\n\n\u00a7619.五谷丰登：获得\u00a7a额外的2张卡牌\n\u00a77  ○●○\n  ○○○\n  ○○○\n无合成配方，可直接使用，需放在荧光物品展示框"},{text:"\u00a7l物品效果及合成配方\u00a7r16/16\n\n\u00a7520.赌徒的交易：令对手的生命值减半，但你将失去所有卡牌\n\u00a77  ○●○\n  ○○○\n  ○○○\n无合成配方，可直接使用，需放在荧光物品展示框"},{text:"\u00a7l卡组选择\u00a7r1/4\n\n\u00a7c进攻型\u00a77：\n 10%铁锭 10%金锭 10%钻石\n\n 12%火药 15%木棍 15%原木\n\n 9%苹果 7%小麦 3%腐肉\n\n       8%五谷丰登\n      1%赌徒的交易\n       ",extra:[{text:"\u00a7n【点击选择】",hover_event:{action:"show_text",value:"【点击选择】"},click_event:{action:"run_command",command:"/function cacardwar:cardset/attack"}}]},{text:"\u00a7l卡组选择\u00a7r2/4\n\n\u00a7d持久型\u00a77：\n 7%铁锭 9%金锭 7%钻石\n\n 7%火药 12%木棍 12%原木\n\n 17%苹果 18%小麦 2%腐肉\n\n       8%五谷丰登\n      1%赌徒的交易\n       ",extra:[{text:"\u00a7n【点击选择】",hover_event:{action:"show_text",value:"【点击选择】"},click_event:{action:"run_command",command:"/function cacardwar:cardset/resist"}}]},{text:"\u00a7l卡组选择\u00a7r3/4\n\n\u00a73召唤型\u00a77：\n 5%铁锭 5%金锭 6%钻石\n\n 8%火药 9%木棍 17%原木\n\n 12%苹果 15%小麦 14%腐肉\n\n       8%五谷丰登\n      1%赌徒的交易\n       ",extra:[{text:"\u00a7n【点击选择】",hover_event:{action:"show_text",value:"【点击选择】"},click_event:{action:"run_command",command:"/function cacardwar:cardset/summon"}}]},{text:"\u00a7l卡组选择\u00a7r4/4\n\n\u00a7a均衡型\u00a77：\n 8%铁锭 8%金锭 7%钻石\n\n 9%火药 13%木棍 14%原木\n\n 14%苹果 15%小麦 3%腐肉\n\n       8%五谷丰登\n      1%赌徒的交易\n       ",extra:[{text:"\u00a7n【点击选择】",hover_event:{action:"show_text",value:"【点击选择】"},click_event:{action:"run_command",command:"/function cacardwar:cardset/average"}}]},{text:"\u00a7l准备\u00a7r\n\n\u00a77  点击下面的选项准备，点击前请再次确认所选的卡组！\n\n\n\n\n\n\n\n        ",extra:[{text:"【\u00a76红方\u00a7r准备】",hover_event:{action:"show_text",value:"点击准备，点击前请再次确认所选的卡组！"},click_event:{action:"run_command",command:"/function cacardwar:preparation/ready_red"}}]}]},custom_data={cacardwar:book}]